			html, body { height: 100%; overflow: hidden; margin: 0; }

			body {
				font-family: 'W95', 'Segoe UI', Tahoma, sans-serif;
				background: url("/bg.jpg") center center / cover no-repeat fixed #008080;
				color: var(--dark);
				display: flex;
				justify-content: center;
				align-items: center;
				padding: 16px 20px;
