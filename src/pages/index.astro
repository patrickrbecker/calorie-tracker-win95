			}

			/* === RAISED BORDER (outset) === */
			.raised {
				border: 2px solid;
				border-color: var(--white) var(--dark) var(--dark) var(--white);
				box-shadow: 1px 1px 0 0 var(--light) inset, -1px -1px 0 0 var(--gray) inset;
			}

			/* === SUNKEN BORDER (inset) === */
			.sunken {
				border: 2px solid;
				border-color: var(--gray) var(--white) var(--white) var(--gray);
				box-shadow: var(--dark) 1px 1px 0 0 inset, var(--light) -1px -1px 0 0 inset;
			}

			/* === WINDOW === */
			.window {
				background: var(--bg);
				border: 2px solid;
				border-color: var(--light) var(--dark) var(--dark) var(--light);
				box-shadow:
					1px 1px 0 1px var(--white) inset,
					-1px -1px 0 1px var(--gray) inset,
					rgba(0,0,0,0.35) 4px 4px 10px 0px;
				width: 100%;
				max-width: 900px;
				display: flex;
				flex-direction: column;
				position: relative;
				max-height: calc(100vh - 32px);
				min-height: 0;
			}

			/* === TITLE BAR === */
			.title-bar {
				background: var(--title-bg);
				color: var(--white);
				font-weight: 700;
				padding: 3px 4px;
				display: flex;
				align-items: center;
				justify-content: space-between;
				user-select: none;
			}
			.title-bar span { padding-left: 2px; font-size: 1rem; }
			.title-controls { display: flex; gap: 2px; }
			.title-controls button {
				width: 18px; height: 18px;
				background: var(--bg);
				border: 2px solid;
				border-color: var(--white) var(--dark) var(--dark) var(--white);
				box-shadow: 1px 1px 0 0 var(--light) inset, -1px -1px 0 0 var(--gray) inset;
				font-family: 'W95', sans-serif;
				font-size: 10px; font-weight: 700;
				cursor: pointer;
				display: flex; align-items: center; justify-content: center;
				padding: 0;
			}
			.title-controls button:active {
				border-color: var(--dark) var(--white) var(--white) var(--dark);
				box-shadow: 1px 1px 0 0 var(--gray) inset;
			}

			/* === TOOLBAR === */
			.toolbar {
				display: flex;
				align-items: center;
				padding: 4px;
				gap: 4px;
				flex-wrap: wrap;
