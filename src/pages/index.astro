			/* === RESET === */
			* { margin: 0; padding: 0; box-sizing: border-box; }

			:root {
				--bg: #c6c6c6;
				--dark: #0a0a0a;
				--white: #fefefe;
				--gray: #848584;
				--light: #dfdfdf;
