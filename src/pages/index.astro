				font-size: 0.85rem;
				flex: 1;
			}
			.status-field:first-child { flex: 2; }

			/* === CHART CONTAINER === */
			.chart-container {
				background: #fff;
				border: 2px solid;
				border-color: var(--gray) var(--white) var(--white) var(--gray);
				box-shadow: var(--dark) 1px 1px 0 0 inset;
				padding: 8px;
				margin-top: 4px;
			}

			/* === RESIZE HANDLE === */
			.resize-handle {
				position: absolute;
				bottom: 4px; right: 4px;
				width: 18px; height: 18px;
				background-image: linear-gradient(135deg,
					var(--white) 16.67%, var(--bg) 16.67%, var(--bg) 33.33%,
					var(--gray) 33.33%, var(--gray) 50%,
					var(--white) 50%, var(--white) 66.67%, var(--bg) 66.67%, var(--bg) 83.33%,
					var(--gray) 83.33%);
				background-size: 8.49px 8.49px;
				clip-path: polygon(100% 0, 0 100%, 100% 100%);
			}

			/* === RESPONSIVE === */
			@media (max-width: 768px) {
				html, body { height: auto; overflow: auto; }
				body { padding: 8px 4px; align-items: flex-start; }
				.window {
					max-height: none;
					max-width: 100%;
				}
				.content-wrapper { overflow: visible; }
				.content { overflow: visible; }
				.win95-scrollbar { display: none; }
				.resize-handle { display: none; }
				.controls-bar { flex-direction: column; }
				.controls-bar .win-input,
				.controls-bar .win-select,
				.controls-bar .btn { width: 100%; }
				.controls-bar .win-input[style] { width: 100% !important; }
				.participant-form.show { flex-direction: column; }
				.participant-form .win-input,
				.participant-form .btn { width: 100%; }
				.week-nav { flex-wrap: wrap; justify-content: center; gap: 6px; text-align: center; }
				.week-nav .btn { order: 0; }
				.week-label { order: -1; width: 100%; }
				.week-label { font-size: 1.1rem; }
				.shoutbox-form { flex-direction: column; }
				.shoutbox-form .win-input,
				.shoutbox-form .btn { width: 100%; }
				.shoutbox-form .win-input[style] { width: 100% !important; }
				.win-table th, .win-table td { padding: 3px 4px; font-size: 0.82rem; }
				.win-table .date-cell { padding-left: 4px; font-size: 0.78rem; }
				.status-bar { flex-direction: column; }
				.status-field:first-child { flex: none; }
				.title-bar span { font-size: 0.85rem; }
				.group-box { padding: 8px; margin-bottom: 6px; }
				.group-box legend { font-size: 0.85rem; }
			}

			/* scrollbar */
			.shoutbox-messages::-webkit-scrollbar { width: 18px; }
			.shoutbox-messages::-webkit-scrollbar-track {
				background: linear-gradient(45deg, var(--bg) 25%, transparent 25%, transparent 75%, var(--bg) 75%) 0 0 / 4px 4px,
							linear-gradient(45deg, var(--bg) 25%, transparent 25%, transparent 75%, var(--bg) 75%) 2px 2px / 4px 4px var(--white);
			}
			.shoutbox-messages::-webkit-scrollbar-thumb {
				background: var(--bg);
				border: 2px solid;
				border-color: var(--white) var(--dark) var(--dark) var(--white);
				box-shadow: 1px 1px 0 0 var(--light) inset, -1px -1px 0 0 var(--gray) inset;
			}
			.btn-icon {
				width: 16px;
				height: 16px;
				vertical-align: middle;
				image-rendering: pixelated;
			}
			.copyright-link {
				color: inherit;
				text-decoration: none;
				cursor: default;
			}
			.copyright-link:hover {
				color: inherit;
				text-decoration: none;
			}
		</style>
	</head>
	<body>
		<div class="window">
			<!-- Title Bar -->
			<div class="title-bar">
				<span>Burning {contestLabel} - Calorie Tracker</span>
				<div class="title-controls">
					<button>_</button>
					<button>&#9633;</button>
					<button>X</button>
				</div>
			</div>

			<!-- Toolbar -->
			<div class="toolbar">
				<button class="btn active-tab" onclick="window.location.href='/'">Tracker</button>
			</div>

			<!-- Week Navigation -->
			<div class="week-nav">
				<button class="btn" id="prevWeek">&lt; Prev Week <img src="/icons/calendar.png" alt="" class="btn-icon"></button>
				<span class="week-label">{contestLabel} - Week {currentWeekNumber}</span>
				<button class="btn" id="nextWeek"><img src="/icons/calendar.png" alt="" class="btn-icon"> Next Week &gt;</button>
			</div>

			<!-- Participant Management -->
			<button class="participant-toggle" type="button">
				<span>Manage Participants ({participants.length} active)</span>
				<span class="toggle-arrow">&#9660;</span>
			</button>
			<div class="participant-form" id="participantForm">
				<input type="text" class="win-input" id="newParticipant" placeholder="Participant name" style="flex:1; min-width:150px;">
				<button type="button" class="btn btn-add" id="addParticipantBtn">Add Participant</button>
				<small style="color: var(--gray);">Case sensitive, cannot be changed</small>
			</div>

			<!-- Controls -->
			<div class="controls-bar">
				<input type="date" class="win-input" id="selectedDate" value={defaultDate}>
				<select class="win-select" id="selectedParticipant">
					<option value="">Select participant</option>
					{participants.map(participant => (
						<option value={participant}>{participant}</option>
					))}
				</select>
				<input type="number" class="win-input" id="calorieAmount" placeholder="Calories" min="0" style="width:100px;">
				<button type="button" class="btn btn-fire" id="addCaloriesBtn">Add Calories <img src="/icons/calc.png" alt="" class="btn-icon"></button>
			</div>

			<!-- Main Content -->
			<div class="content-wrapper">
			<div class="content" id="scrollContent">
				<!-- Weekly Table -->
				<fieldset class="group-box">
					<legend>Week {currentWeekNumber} - Daily Tracking</legend>
					<div class="group-box-content">
						<div class="table-scroll">
							<table class="win-table">
								<thead>
									<tr>
										<th>Date</th>
										{participants.map(participant => (
											<th>{participant}</th>
										))}
									</tr>
								</thead>
								<tbody>
									{weekDays.map(day => (
										<tr>
											<td class="date-cell">{day.displayDate}</td>
											{participants.map(participant => (
												<td class="editable-cell"
													data-participant={participant}
													data-date={day.date}
													data-week={currentWeekNumber}
													title="Click to edit">
													<span class="calorie-value">{weekData[day.date]?.[participant] || ''}</span>
												</td>
											))}
										</tr>
									))}
									<!-- Weekly Total Row -->
									<tr class="total-row">
										<td class="date-cell">WEEKLY TOTAL</td>
										{participants.map(participant => (
											<td>{weeklyTotals[participant] || 0}</td>
										))}
									</tr>
								</tbody>
							</table>
						</div>
					</div>
				</fieldset>

				{participants.length === 0 && (
					<fieldset class="group-box">
						<legend>Getting Started</legend>
						<div class="group-box-content" style="text-align: center; padding: 20px;">
							<p><strong>No participants yet!</strong></p>
							<p>Add your first participant above to start the contest.</p>
						</div>
					</fieldset>
				)}

				<!-- Overall Leaderboard -->
				{participants.length > 0 && (
					<fieldset class="group-box">
						<legend>Overall Calories Burned</legend>
						<div class="group-box-content">
							<div class="table-scroll">
								<table class="win-table" id="overallTable">
									<thead>
										<tr>
											<th>Rank</th>
											<th>Participant</th>
											<th>Total Calories</th>
											<th>Pizza Slices Burned</th>
											<th>Torta's Pounded</th>
										</tr>
									</thead>
									<tbody id="overallTableBody">
										{participantTotals
											.sort((a, b) => b.total_calories - a.total_calories)
											.map((participant, index) => {
												const rank = index + 1;
												let rankClass = '';
												let rankText = `#${rank}`;

												if (rank === 1) { rankClass = 'rank-gold'; rankText = '#1'; }
												else if (rank === 2) { rankClass = 'rank-silver'; rankText = '#2'; }
												else if (rank === 3) { rankClass = 'rank-bronze'; rankText = '#3'; }

												const pizzaSlices = Math.floor(participant.total_calories / 300);
												const tortasPounded = Math.floor(participant.total_calories / 100);

												return (
													<tr>
														<td class={rankClass} style="text-align:center; font-weight:700;">{rankText}</td>
														<td style="text-align:left; font-weight:700;">{participant.name}</td>
														<td>{participant.total_calories.toLocaleString()}</td>
														<td>{pizzaSlices.toLocaleString()}</td>
														<td>{tortasPounded.toLocaleString()}</td>
													</tr>
												);
											})}
									</tbody>
								</table>
							</div>
						</div>
					</fieldset>
				)}

				<!-- Chart -->
				{participants.length > 0 && (
					<fieldset class="group-box">
						<legend>Cumulative Calorie Progress - {contestLabel}</legend>
						<div class="group-box-content">
							<div class="chart-container">
								<canvas id="calorieChart" width="400" height="200"></canvas>
							</div>
						</div>
					</fieldset>
				)}

				<!-- Shoutbox -->
				<div class="shoutbox-window">
					<div class="shoutbox-title">Team Chat</div>
					<div class="shoutbox-messages" id="shoutboxMessages">
						<div style="text-align: center; color: var(--gray); padding: 10px;">
							Loading messages...
						</div>
					</div>
					<div class="shoutbox-form">
						<input type="text" class="win-input" id="shoutUsername" placeholder="Name" maxlength="255" style="width:120px; flex:none;">
						<input type="text" class="win-input" id="shoutMessage" placeholder="Type a message..." maxlength="500">
						<button type="button" class="btn" id="sendShoutBtn">Send</button>
					</div>
				</div>
			</div>

			<!-- Custom Win95 Scrollbar -->
			<div class="win95-scrollbar" id="customScrollbar">
				<div class="scrollbar-btn scrollbar-up" id="scrollUp">
					<svg height="26" width="26" viewBox="0 0 26 26"><g transform="rotate(180 13 13)"><polygon fill="#0a0a0a" points="6,10 20,10 13,17"></polygon></g></svg>
				</div>
				<div class="scrollbar-track" id="scrollTrack">
					<div class="scrollbar-thumb" id="scrollThumb"></div>
				</div>
				<div class="scrollbar-btn scrollbar-down" id="scrollDown">
					<svg height="26" width="26" viewBox="0 0 26 26"><polygon fill="#0a0a0a" points="6,10 20,10 13,17"></polygon></svg>
				</div>
			</div>
			</div>

			<!-- Status Bar -->
			<div class="status-bar">
				<div class="status-field"><img src="/icons/info.png" alt="" class="btn-icon"> Burning {contestLabel} - Active Calorie Contest | <a href="/admin" class="copyright-link">&copy; Pat Becker</a></div>
				<div class="status-field">Week {currentWeekNumber} of 5</div>
				<div class="status-field">{participants.length} participants</div>
			</div>

			<div class="resize-handle"></div>
		</div>

		<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
		<script define:vars={{ currentWeek: currentWeekNumber, chartData: participantTotals, weekData: weekData, participants: participants, weekDays: weekDays, allWeeksData: allWeeksData, daysInMonth: daysInCurrentMonth }}>
			// currentWeek is now available from define:vars

			// Initialize chart if we have data
			let calorieChart = null;

			function initChart() {
				const canvas = document.getElementById('calorieChart');
				if (!canvas || !participants || participants.length === 0) return;

				const ctx = canvas.getContext('2d');

				// Destroy existing chart if it exists
				if (calorieChart) {
					calorieChart.destroy();
				}

				// Generate dates for entire current month
				const today = new Date();
				const chartYear = today.getFullYear();
				const chartMonth = today.getMonth();
				const maxDay = daysInMonth;

				const allDates = [];
				for (let day = 1; day <= maxDay; day++) {
					const mm = String(chartMonth + 1).padStart(2, '0');
					const dd = String(day).padStart(2, '0');
					const dateStr = `${chartYear}-${mm}-${dd}`;
					const date = new Date(chartYear, chartMonth, day);
					allDates.push({
						date: dateStr,
						displayDate: date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
					});
				}

				const labels = allDates.map(d => d.displayDate);

				const colors = ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF', '#FF9F40'];

				const todayStr = `${chartYear}-${String(chartMonth + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;

				const datasets = participants.map((participant, index) => {
					let cumulativeTotal = 0;
					const data = allDates.map(dateObj => {
						if (dateObj.date > todayStr) return null;
						const dailyCalories = allWeeksData[dateObj.date]?.[participant] || 0;
						cumulativeTotal += dailyCalories;
						return cumulativeTotal;
					});

					const color = colors[index % colors.length];

					return {
						label: participant,
						data: data,
						borderColor: color,
						backgroundColor: color + '1A',
						borderWidth: 3,
						fill: false,
						tension: 0.4,
						pointBackgroundColor: color,
						pointBorderColor: color,
						pointBorderWidth: 2,
						pointRadius: 3
					};
				});

				calorieChart = new Chart(ctx, {
					type: 'line',
					data: { labels: labels, datasets: datasets },
					options: {
						responsive: true,
						plugins: {
							legend: { display: true, position: 'top' },
							tooltip: {
								callbacks: {
									label: function(context) {
										return `${context.dataset.label}: ${context.parsed.y.toLocaleString()} cal`;
									}
								}
							}
						},
						scales: {
							y: { beginAtZero: true, ticks: { precision: 0 }, title: { display: true, text: 'Calories Burned' } },
							x: { title: { display: true, text: 'Date' } }
						}
					}
				});
			}

			function updateChart() {}

			async function updateOverallTable() {
				try {
					const response = await fetch('/api/debug-data');
					const result = await response.json();

					if (response.ok && result.participantTotals) {
						const sortedTotals = result.participantTotals.sort((a, b) => b.total_calories - a.total_calories);
						const tableBody = document.getElementById('overallTableBody');

						if (tableBody) {
							tableBody.innerHTML = sortedTotals.map((participant, index) => {
								const rank = index + 1;
								let rankClass = '';
								let rankText = `#${rank}`;

								if (rank === 1) { rankClass = 'rank-gold'; rankText = '#1'; }
								else if (rank === 2) { rankClass = 'rank-silver'; rankText = '#2'; }
								else if (rank === 3) { rankClass = 'rank-bronze'; rankText = '#3'; }

								const safeName = document.createElement('div');
								safeName.textContent = participant.name;
								const escapedName = safeName.innerHTML;

								const pizzaSlices = Math.floor(participant.total_calories / 300);

								return `
									<tr>
										<td class="${rankClass}" style="text-align:center; font-weight:700;">${rankText}</td>
										<td style="text-align:left; font-weight:700;">${escapedName}</td>
										<td>${parseInt(participant.total_calories).toLocaleString()}</td>
										<td>${pizzaSlices.toLocaleString()}</td>
									</tr>
								`;
							}).join('');
						}
					}
				} catch (error) {
					console.error('Error updating overall table:', error);
				}
			}

			window.toggleParticipantForm = function() {
				const form = document.getElementById('participantForm');
				const toggle = document.querySelector('.participant-toggle');

				if (form && toggle) {
					if (form.classList.contains('show')) {
						form.classList.remove('show');
						toggle.classList.remove('expanded');
					} else {
						form.classList.add('show');
						toggle.classList.add('expanded');
					}
				}
			}

			async function addParticipant() {
				const name = document.getElementById('newParticipant').value.trim();
				if (!name) {
					alert('Please enter a participant name');
					return;
				}

				try {
					const response = await fetch('/api/add-participant', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ name })
					});

					const result = await response.json();

					if (response.ok) {
						alert(`"${name}" has been added to the contest!`);
						document.getElementById('newParticipant').value = '';
						window.location.reload();
					} else {
						alert(result.error || 'Failed to add participant');
					}
				} catch (error) {
					alert('Error adding participant. Please try again.');
				}
			}

			async function addCalories() {
				const date = document.getElementById('selectedDate').value;
				const participant = document.getElementById('selectedParticipant').value.trim();
				const calories = parseInt(document.getElementById('calorieAmount').value);

				if (!date || !participant || calories === undefined || calories === null || isNaN(calories) || calories < 0) {
					alert('Please fill in all fields with valid values');
					return;
				}

				const correctWeek = getWeekForDate(date);

				try {
					const response = await fetch('/api/add-calories', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ date, participant, calories, week: correctWeek })
					});

					const result = await response.json();
					if (response.ok) {
						const dateParts = date.split('-');
						const month = new Date(0, parseInt(dateParts[1]) - 1).toLocaleDateString('en-US', { month: 'short' });
						const formattedDate = `${month} ${parseInt(dateParts[2])}`;
						alert(`${calories} calories added for ${participant} on ${formattedDate}!`);
						document.getElementById('selectedParticipant').value = '';
						document.getElementById('calorieAmount').value = '';

						window.location.reload();
					} else {
						alert(result.error || 'Failed to add calories');
					}
				} catch (error) {
					alert('Error adding calories. Please try again.');
				}
			}

			function getWeekForDate(dateString) {
				const day = parseInt(dateString.split('-')[2]);
				return Math.min(Math.ceil(day / 7), 5);
			}

			async function changeWeek(direction) {
				const newWeek = currentWeek + direction;

				if (newWeek < 1 || newWeek > 5) return;

				try {
					window.location.href = `/?week=${newWeek}`;
				} catch (error) {
					console.error('Error changing week:', error);
					alert('Error changing week: ' + error.message);
				}
			}

			document.addEventListener('DOMContentLoaded', function() {
				initChart();

				const toggleButton = document.querySelector('.participant-toggle');
				if (toggleButton) {
					toggleButton.addEventListener('click', function(e) {
						e.preventDefault();
						window.toggleParticipantForm();
					});
				}

				const addButton = document.getElementById('addParticipantBtn');
				if (addButton) {
					addButton.addEventListener('click', function(e) {
						e.preventDefault();
						addParticipant();
					});
				}

				const addCaloriesButton = document.getElementById('addCaloriesBtn');
				if (addCaloriesButton) {
					addCaloriesButton.addEventListener('click', function(e) {
						e.preventDefault();
						addCalories();
					});
				}

				const prevWeekButton = document.getElementById('prevWeek');
				if (prevWeekButton) {
					prevWeekButton.addEventListener('click', function(e) {
						e.preventDefault();
						changeWeek(-1);
					});
				}

				const nextWeekButton = document.getElementById('nextWeek');
				if (nextWeekButton) {
					nextWeekButton.addEventListener('click', function(e) {
						e.preventDefault();
						changeWeek(1);
					});
				}

				initInlineEditing();

				const dateInput = document.getElementById('selectedDate');
				if (dateInput && !dateInput.value) {
					const now = new Date();
					const y = now.getFullYear();
					const m = String(now.getMonth() + 1).padStart(2, '0');
					const d = String(now.getDate()).padStart(2, '0');
					dateInput.value = `${y}-${m}-${d}`;
				}
				if (dateInput) {
					dateInput.addEventListener('change', async function(e) {
						const selectedDate = e.target.value;
						const selectedWeek = getWeekForDate(selectedDate);

						if (selectedWeek !== currentWeek) {
							window.location.href = `/?week=${selectedWeek}&date=${selectedDate}`;
						}
					});
				}

				loadShoutboxMessages();
				shoutboxRefreshInterval = setInterval(loadShoutboxMessages, 10000);

				const sendBtn = document.getElementById('sendShoutBtn');
				if (sendBtn) {
					sendBtn.addEventListener('click', sendShout);
				}

				const messageInput = document.getElementById('shoutMessage');
				if (messageInput) {
					messageInput.addEventListener('keypress', function(e) {
						if (e.key === 'Enter') sendShout();
					});
				}

				const usernameInput = document.getElementById('shoutUsername');
				if (usernameInput) {
					usernameInput.addEventListener('keypress', function(e) {
						if (e.key === 'Enter') document.getElementById('shoutMessage').focus();
					});
				}
			});

			document.getElementById('newParticipant').addEventListener('keypress', function(e) {
				if (e.key === 'Enter') addParticipant();
			});

			document.getElementById('calorieAmount').addEventListener('keypress', function(e) {
				if (e.key === 'Enter') addCalories();
			});

			function initInlineEditing() {
				const table = document.querySelector('.win-table');
				if (table) {
					table.addEventListener('click', function(e) {
						const cell = e.target.closest('.editable-cell');
						if (cell && !cell.classList.contains('editing')) {
							const valueSpan = cell.querySelector('.calorie-value');
							startEdit(cell);
						}
					});
				}
			}

			function startEdit(cell) {
				const valueSpan = cell.querySelector('.calorie-value');
				const originalValue = valueSpan ? valueSpan.textContent.trim() : '';
				cell.setAttribute('data-original-value', originalValue);

				const input = document.createElement('input');
				input.type = 'number';
				input.className = 'edit-input';
				input.value = originalValue;
				input.min = '0';
				input.max = '50000';

				cell.classList.add('editing');
				cell.innerHTML = '';
				cell.appendChild(input);
				input.focus();
				input.select();

				input.addEventListener('keydown', function(e) {
					if (e.key === 'Enter') {
						e.preventDefault();
						saveEdit(cell, input.value, originalValue);
					} else if (e.key === 'Escape') {
						e.preventDefault();
						cancelEdit(cell, originalValue);
					}
				});

				input.addEventListener('blur', function() {
					if (input.value !== originalValue) {
						saveEdit(cell, input.value, originalValue);
					} else {
						cancelEdit(cell, originalValue);
					}
				});
			}

			async function saveEdit(cell, newValue, originalValue) {
				const participant = cell.getAttribute('data-participant');
				const date = cell.getAttribute('data-date');
				const week = parseInt(cell.getAttribute('data-week'));

				const numValue = parseInt(newValue);
				if (isNaN(numValue) || numValue < 0 || numValue > 50000) {
					alert('Please enter a valid number between 0 and 50,000');
					const input = cell.querySelector('.edit-input');
					if (input) input.focus();
					return;
				}

				cell.classList.add('saving');
				cell.classList.remove('editing');
				cell.innerHTML = '<span class="calorie-value">Saving...</span>';

				try {
					const response = await fetch('/api/update-calories', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({
							participant: participant,
							date: date,
							calories: numValue,
							week: week
						})
					});

					const result = await response.json();

					if (response.ok) {
						location.reload();
					} else {
						throw new Error(result.error || 'Failed to update calories');
					}
				} catch (error) {
					console.error('Error updating calories:', error);
					cell.classList.add('error');
					cell.classList.remove('saving');
					cell.innerHTML = `<span class="calorie-value">${originalValue}</span>`;

					alert('Error updating calories: ' + error.message + '. Changes have been reverted.');

					setTimeout(() => {
						cell.classList.remove('error');
					}, 3000);
				}
			}

			function cancelEdit(cell, originalValue) {
				cell.classList.remove('editing');
				cell.innerHTML = `<span class="calorie-value">${originalValue}</span>`;
			}

			let shoutboxRefreshInterval;

			async function loadShoutboxMessages() {
				try {
					const response = await fetch('/api/get-shouts?limit=15');
					const result = await response.json();

					const messagesContainer = document.getElementById('shoutboxMessages');
					if (response.ok && result.data) {
						if (result.data.length === 0) {
							messagesContainer.innerHTML = '<div style="text-align:center; color:var(--gray); padding:10px;">No messages yet. Be the first to say something!</div>';
						} else {
							messagesContainer.innerHTML = result.data.map(msg => {
								const date = new Date(msg.created_at);
								const timeStr = date.toLocaleTimeString('en-US', {
									hour: 'numeric',
									minute: '2-digit',
									hour12: true
								});

								const safeUsername = document.createElement('div');
								safeUsername.textContent = msg.username;
								const escapedUsername = safeUsername.innerHTML;

								const safeMessage = document.createElement('div');
								safeMessage.textContent = msg.message;
								const escapedMessage = safeMessage.innerHTML;

								return `
									<div class="shout-msg">
										<span class="shout-user">${escapedUsername}</span>
										<span class="shout-time">${timeStr}</span>
										<span class="shout-text">${escapedMessage}</span>
									</div>
								`;
							}).join('');

							messagesContainer.scrollTop = messagesContainer.scrollHeight;
						}
					} else {
						messagesContainer.innerHTML = '<div style="text-align:center; color:#a80000; padding:10px;">Error loading messages</div>';
					}
				} catch (error) {
					console.error('Error loading shoutbox:', error);
					const messagesContainer = document.getElementById('shoutboxMessages');
					messagesContainer.innerHTML = '<div style="text-align:center; color:#a80000; padding:10px;">Error loading messages</div>';
				}
			}

			async function sendShout() {
				const usernameInput = document.getElementById('shoutUsername');
				const messageInput = document.getElementById('shoutMessage');
				const sendBtn = document.getElementById('sendShoutBtn');

				const username = usernameInput.value.trim();
				const message = messageInput.value.trim();

				if (!username || !message) {
					alert('Please enter both your name and a message');
					return;
				}

				sendBtn.disabled = true;
				sendBtn.textContent = 'Sending...';

				try {
					const response = await fetch('/api/add-shout', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ username, message })
					});

					const result = await response.json();

					if (response.ok) {
						messageInput.value = '';
						await loadShoutboxMessages();
					} else {
						alert(result.error || 'Failed to send message');
					}
				} catch (error) {
					console.error('Error sending shout:', error);
					alert('Error sending message. Please try again.');
				} finally {
					sendBtn.disabled = false;
					sendBtn.textContent = 'Send';
				}
			}
		</script>
		<script>
			// Win95 Custom Scrollbar
			(function() {
				const content = document.getElementById('scrollContent');
				const thumb = document.getElementById('scrollThumb');
				const track = document.getElementById('scrollTrack');
				const upBtn = document.getElementById('scrollUp');
				const downBtn = document.getElementById('scrollDown');
				if (!content || !thumb || !track) return;

				function updateThumb() {
					const { scrollTop, scrollHeight, clientHeight } = content;
					if (scrollHeight <= clientHeight) {
						thumb.style.display = 'none';
						return;
					}
					thumb.style.display = 'block';
					const trackH = track.clientHeight;
					const thumbH = Math.max(30, (clientHeight / scrollHeight) * trackH);
					const maxThumbTop = trackH - thumbH;
					const scrollFraction = scrollTop / (scrollHeight - clientHeight);
					thumb.style.height = thumbH + 'px';
					thumb.style.top = (scrollFraction * maxThumbTop) + 'px';
				}

				content.addEventListener('scroll', updateThumb);
				new ResizeObserver(updateThumb).observe(content);
				updateThumb();

				// Drag thumb
				let dragging = false, dragStartY = 0, dragStartTop = 0;
				thumb.addEventListener('mousedown', function(e) {
					e.preventDefault();
					dragging = true;
					dragStartY = e.clientY;
					dragStartTop = parseInt(thumb.style.top) || 0;
					document.body.style.userSelect = 'none';
				});
				window.addEventListener('mousemove', function(e) {
					if (!dragging) return;
					const { scrollHeight, clientHeight } = content;
					const trackH = track.clientHeight;
					const thumbH = thumb.offsetHeight;
					const maxThumbTop = trackH - thumbH;
					const delta = e.clientY - dragStartY;
					const newTop = Math.max(0, Math.min(maxThumbTop, dragStartTop + delta));
					const scrollFraction = newTop / maxThumbTop;
					content.scrollTop = scrollFraction * (scrollHeight - clientHeight);
				});
				window.addEventListener('mouseup', function() {
					dragging = false;
					document.body.style.userSelect = '';
				});

				// Click track to jump
				track.addEventListener('mousedown', function(e) {
					if (e.target === thumb) return;
					const rect = track.getBoundingClientRect();
					const clickY = e.clientY - rect.top;
					const thumbCenter = (parseInt(thumb.style.top) || 0) + thumb.offsetHeight / 2;
					const { scrollHeight, clientHeight } = content;
					const pageSize = clientHeight * 0.8;
					content.scrollTop += clickY < thumbCenter ? -pageSize : pageSize;
				});

				// Arrow buttons with repeat
				let scrollInterval;
				function startScroll(dir) {
					content.scrollTop += dir * 40;
					scrollInterval = setInterval(() => content.scrollTop += dir * 40, 50);
				}
				function stopScroll() { clearInterval(scrollInterval); }
				upBtn.addEventListener('mousedown', function(e) { e.preventDefault(); startScroll(-1); });
				downBtn.addEventListener('mousedown', function(e) { e.preventDefault(); startScroll(1); });
				window.addEventListener('mouseup', stopScroll);
			})();
		</script>
	</body>
</html>