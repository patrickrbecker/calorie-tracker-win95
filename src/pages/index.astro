				background-image: url("data:image/svg+xml,%3Csvg width='4' height='4' xmlns='http://www.w3.org/2000/svg'%3E%3Crect width='2' height='2' fill='%23c6c6c6'/%3E%3Crect x='2' y='2' width='2' height='2' fill='%23c6c6c6'/%3E%3Crect x='2' width='2' height='2' fill='%23fefefe'/%3E%3Crect y='2' width='2' height='2' fill='%23fefefe'/%3E%3C/svg%3E");
				background-size: 4px 4px;
