---
// Simple admin page for production setup
import Analytics from '@vercel/analytics/astro';
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Admin - Calorie Tracker</title>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-4C0YRJ9CXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-4C0YRJ9CXX');
    </script>

    <Analytics />
    <style>
        @font-face {
            font-family: 'W95';
            src: url('https://unpkg.com/react95@4.0.0/dist/fonts/ms_sans_serif.woff2') format('woff2');
            font-weight: 400;
        }
        @font-face {
            font-family: 'W95';
            src: url('https://unpkg.com/react95@4.0.0/dist/fonts/ms_sans_serif_bold.woff2') format('woff2');
            font-weight: 700;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --bg: #c6c6c6;
            --dark: #0a0a0a;
            --white: #fefefe;
            --gray: #848584;
            --light: #dfdfdf;
            --title-bg: #060084;
            --teal: #008080;
            --red: #a80000;
        }

        html { font-size: 14px; }

        body {
            font-family: 'W95', 'Segoe UI', Tahoma, sans-serif;
            background: url("/bg.jpg") center center / cover no-repeat fixed #008080;
            color: var(--dark);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 40px 20px;
            line-height: 1.4;
        }

        .window {
            background: var(--bg);
            border: 2px solid;
            border-color: var(--light) var(--dark) var(--dark) var(--light);
            box-shadow:
                1px 1px 0 1px var(--white) inset,
                -1px -1px 0 1px var(--gray) inset,
                rgba(0,0,0,0.35) 4px 4px 10px 0px;
            width: 100%;
            max-width: 500px;
            position: relative;
        }

        .title-bar {
            background: var(--title-bg);
            color: var(--white);
            font-weight: 700;
            padding: 3px 4px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            user-select: none;
        }
        .title-bar span { padding-left: 2px; }
        .title-controls { display: flex; gap: 2px; }
        .title-controls button {
            width: 18px; height: 18px;
            background: var(--bg);
            border: 2px solid;
            border-color: var(--white) var(--dark) var(--dark) var(--white);
            box-shadow: 1px 1px 0 0 var(--light) inset, -1px -1px 0 0 var(--gray) inset;
            font-family: 'W95', sans-serif;
            font-size: 10px; font-weight: 700;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            padding: 0;
        }
        .title-controls button:active {
            border-color: var(--dark) var(--white) var(--white) var(--dark);
            box-shadow: 1px 1px 0 0 var(--gray) inset;
        }

        .toolbar {
            display: flex;
            align-items: center;
            padding: 4px;
            gap: 4px;
        }

        .btn {
            font-family: 'W95', sans-serif;
            font-size: 1rem;
            background: var(--bg);
            color: var(--dark);
            border: 2px solid;
            border-color: var(--white) var(--dark) var(--dark) var(--white);
            box-shadow: 1px 1px 0 0 var(--light) inset, -1px -1px 0 0 var(--gray) inset;
            padding: 3px 12px;
            height: 28px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            user-select: none;
        }
        .btn:active {
            border-color: var(--dark) var(--white) var(--white) var(--dark);
            box-shadow: 1px 1px 0 0 var(--gray) inset;
            padding-top: 5px;
        }
        .btn:disabled {
            color: var(--gray);
            text-shadow: 1px 1px 0 var(--white);
            cursor: default;
        }
        .btn.active-tab {
            background: linear-gradient(45deg, var(--bg) 25%, transparent 25%, transparent 75%, var(--bg) 75%) 0 0 / 4px 4px,
                        linear-gradient(45deg, var(--bg) 25%, transparent 25%, transparent 75%, var(--bg) 75%) 2px 2px / 4px 4px var(--white);
            border-color: var(--dark) var(--white) var(--white) var(--dark);
            box-shadow: 1px 1px 0 0 var(--gray) inset;
        }
        .btn-danger {
            background: var(--bg);
            font-weight: 700;
        }

        .content { padding: 12px; }

        .group-box {
            position: relative;
            border: 2px solid var(--white);
            padding: 12px;
            margin-bottom: 8px;
            box-shadow: var(--gray) -1px -1px 0 1px, var(--gray) -1px -1px 0 1px inset;
        }
        .group-box legend {
            position: absolute;
            top: 0; left: 8px;
            transform: translateY(calc(-50% - 2px));
            padding: 0 8px;
            background: var(--bg);
            font-weight: 700;
        }
        .group-box-content { margin-top: 6px; }

        .danger-box {
            border-color: #ff0000;
            box-shadow: #a80000 -1px -1px 0 1px, #a80000 -1px -1px 0 1px inset;
        }
        .danger-box legend { color: var(--red); }

        .info-box {
            background: #fff;
            border: 2px solid;
            border-color: var(--gray) var(--white) var(--white) var(--gray);
            box-shadow: var(--dark) 1px 1px 0 0 inset;
            padding: 8px;
            margin-bottom: 8px;
        }

        .status-msg {
            margin-top: 8px;
            padding: 8px;
            display: none;
            font-weight: 700;
        }
        .status-msg.success {
            background: #fff;
            border: 2px solid;
            border-color: var(--gray) var(--white) var(--white) var(--gray);
            color: #008000;
        }
        .status-msg.error {
            background: #fff;
            border: 2px solid;
            border-color: var(--gray) var(--white) var(--white) var(--gray);
            color: var(--red);
        }

        ul {
            list-style: none;
            padding: 0;
            margin: 8px 0;
        }
        ul li::before {
            content: '- ';
        }

        .status-bar {
            display: flex;
            border-top: 2px solid var(--gray);
            box-shadow: 0 -1px 0 0 var(--white);
        }
        .status-field {
            border: 2px solid;
            border-color: var(--gray) var(--white) var(--white) var(--gray);
            padding: 2px 6px;
            font-size: 0.85rem;
            flex: 1;
        }

        .resize-handle {
            position: absolute;
            bottom: 4px; right: 4px;
            width: 18px; height: 18px;
            background-image: linear-gradient(135deg,
                var(--white) 16.67%, var(--bg) 16.67%, var(--bg) 33.33%,
                var(--gray) 33.33%, var(--gray) 50%,
                var(--white) 50%, var(--white) 66.67%, var(--bg) 66.67%, var(--bg) 83.33%,
                var(--gray) 83.33%);
            background-size: 8.49px 8.49px;
            clip-path: polygon(100% 0, 0 100%, 100% 100%);
        }

        p + p { margin-top: 6px; }
    </style>
</head>
<body>
    <div class="window">
        <div class="title-bar">
            <span>Calorie Tracker - Admin</span>
            <div class="title-controls">
                <button>_</button>
                <button>&#9633;</button>
                <button>X</button>
            </div>
        </div>

        <div class="toolbar">
            <button class="btn" onclick="window.location.href='/'">Tracker</button>
            <button class="btn active-tab" onclick="window.location.href='/admin'">Admin</button>
        </div>

        <div class="content">
            <fieldset class="group-box">
                <legend>Production Setup</legend>
                <div class="group-box-content">
                    <div class="info-box">
                        <p>Use this page to prepare the calorie tracker for real users by clearing all test data.</p>
                    </div>
                </div>
            </fieldset>

            <fieldset class="group-box danger-box">
                <legend>Danger Zone - Reset Database</legend>
                <div class="group-box-content">
                    <p>This will <strong>permanently delete</strong>:</p>
                    <ul>
                        <li>All participants (test users)</li>
                        <li>All calorie entries</li>
                        <li>Reset current week to 1</li>
                    </ul>
                    <p><strong>This action cannot be undone!</strong></p>
                    <div style="margin-top: 10px;">
                        <button class="btn btn-danger" id="clearButton">Clear All Data & Reset</button>
                    </div>

                    <div id="status" class="status-msg"></div>
                </div>
            </fieldset>
        </div>

        <div class="status-bar">
            <div class="status-field">Admin Panel</div>
        </div>

        <div class="resize-handle"></div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('clearButton').addEventListener('click', clearAllData);
        });

        async function clearAllData() {
            const button = document.getElementById('clearButton');
            const status = document.getElementById('status');

            const adminKey = prompt('Enter admin key:');
            if (!adminKey) return;

            if (!confirm('Are you absolutely sure? This will delete ALL data and cannot be undone!')) {
                return;
            }

            button.disabled = true;
            button.textContent = 'Clearing data...';
            status.style.display = 'none';

            try {
                const response = await fetch('/api/clear', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'x-admin-key': adminKey
                    }
                });

                const result = await response.json();

                if (response.ok) {
                    status.className = 'status-msg success';
                    status.textContent = result.message;
                    status.style.display = 'block';

                    setTimeout(() => {
                        window.location.href = '/';
                    }, 2000);
                } else {
                    throw new Error(result.error || 'Failed to clear data');
                }
            } catch (error) {
                status.className = 'status-msg error';
                status.textContent = 'Error: ' + error.message;
                status.style.display = 'block';
            } finally {
                button.disabled = false;
                button.textContent = 'Clear All Data & Reset';
            }
        }
    </script>
</body>
</html>